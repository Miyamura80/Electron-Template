{
    "name": "electron-template",
    "version": "0.1.0",
    "description": "⚛️ Agent-ergonomic opinionated Electron template",
    "type": "module",
    "scripts": {
        "dev": "bun run --watch src/index.ts",
        "start": "bun run src/index.ts",
        "fmt": "biome check --write",
        "lint": "biome check",
        "deadcode": "knip",
        "typecheck": "tsc --noEmit",
        "lint:links": "find . -name '*.md' -not -path './node_modules/*' -not -path './docs/*' | xargs markdown-link-check --quiet --config .markdown-link-check.json",
        "ci": "bun run lint && bun run deadcode && bun run typecheck && bun run lint:links",
        "test": "bun test",
        "test:fast": "bun test --timeout 5000",
        "test:watch": "bun test --watch"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.0",
        "@types/bun": "^1.3.9",
        "@types/to-ico": "^1.1.3",
        "dependency-cruiser": "^17.3.8",
        "jscpd": "^4.0.8",
        "knip": "^5.0.0",
        "markdown-link-check": "^3.12.0",
        "typescript": "^5.7.0"
    },
    "dependencies": {
        "@clack/prompts": "^1.0.1",
        "@google/genai": "^1.42.0",
        "sharp": "^0.34.5",
        "to-ico": "^1.1.5",
        "yaml": "^2.8.2",
        "zod": "^4.3.6"
    }
}
