{
    "name": "electron-template",
    "version": "0.1.0",
    "description": "⚛️ Agent-ergonomic opinionated Electron template",
    "type": "module",
    "main": "out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "start": "electron-vite preview",
        "package": "electron-vite build && electron-builder",
        "package:mac": "electron-vite build && electron-builder --mac",
        "package:win": "electron-vite build && electron-builder --win",
        "package:linux": "electron-vite build && electron-builder --linux",
        "fmt": "biome check --write",
        "lint": "biome check",
        "deadcode": "knip",
        "typecheck": "tsc --noEmit",
        "lint:links": "find . -name '*.md' -not -path './node_modules/*' -not -path './docs/*' -not -path './Tauri-Template/*' | xargs markdown-link-check --quiet --config .markdown-link-check.json",
        "ci": "bun run lint && bun run deadcode && bun run typecheck && bun run lint:links",
        "test": "bun test",
        "test:fast": "bun test --timeout 5000",
        "test:watch": "bun test --watch"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.0",
        "@types/bun": "^1.3.9",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@types/to-ico": "^1.1.3",
        "@vitejs/plugin-react": "^5.1.1",
        "dependency-cruiser": "^17.3.8",
        "electron": "^33.2.0",
        "electron-builder": "^25.1.8",
        "electron-vite": "^2.3.0",
        "jscpd": "^4.0.8",
        "knip": "^5.0.0",
        "markdown-link-check": "^3.12.0",
        "typescript": "^5.7.0",
        "vite": "^5.4.11"
    },
    "fileLength": {
        "max_lines": 500,
        "exclude": ["onboard.ts"]
    },
    "dependencies": {
        "@clack/prompts": "^1.0.1",
        "@google/genai": "^1.42.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "sharp": "^0.34.5",
        "to-ico": "^1.1.5",
        "yaml": "^2.8.2",
        "zod": "^4.3.6"
    }
}
