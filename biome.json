{
    "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
    "organizeImports": {
        "enabled": true
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 88
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "complexity": {
                "noExcessiveCognitiveComplexity": {
                    "level": "error",
                    "options": {
                        "maxAllowedComplexity": 15
                    }
                }
            },
            "correctness": {
                "noUnusedImports": "error",
                "noUnusedVariables": "error"
            },
            "suspicious": {
                "noExplicitAny": "warn"
            },
            "style": {
                "noNonNullAssertion": "warn",
                "useConst": "error"
            }
        }
    },
    "json": {
        "formatter": {
            "enabled": true
        }
    },
    "files": {
        "ignore": [
            "node_modules",
            "out",
            "release",
            "dist",
            "*.min.js",
            "bun.lock",
            "docs",
            "manual_docs",
            "media",
            "Tauri-Template"
        ]
    }
}
