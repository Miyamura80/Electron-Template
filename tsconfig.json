{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "jsx": "react-jsx",
        "types": ["@types/bun", "electron"],
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "skipLibCheck": true,
        "noEmit": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "allowSyntheticDefaultImports": true,
        "baseUrl": ".",
        "paths": {
            "@main/*": ["src/main/*"],
            "@preload/*": ["src/preload/*"],
            "@renderer/*": ["src/renderer/src/*"],
            "@shared/*": ["src/shared/*"]
        }
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "tests/**/*.ts",
        "scripts/**/*.ts",
        "electron.vite.config.ts",
        "onboard.ts"
    ],
    "exclude": ["node_modules", "out", "release", "Tauri-Template"]
}
